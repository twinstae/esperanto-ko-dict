---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Esperanto–Korean dictionary">
	<main class="hero">
		<p class="eyebrow">Offline-friendly lookup</p>
		<h1>Esperanto–Korean</h1>
		<p class="lede">
			Search the dictionary. Data loads once into your browser and is cached locally.
		</p>
		<form class="search" id="home-search" action="#" method="get">
			<label class="sr-only" for="q">Search Esperanto word</label>
			<input
				id="q"
				name="q"
				type="search"
				autocomplete="off"
				placeholder="e.g. Kateĥismo"
				required
			/>
			<button type="submit">Search</button>
		</form>
	</main>
</Layout>

<script>
	import { wordsPageHref } from "../lib/words-route";

	const form = document.getElementById("home-search");
	if (form instanceof HTMLFormElement) {
		form.addEventListener("submit", (e) => {
			e.preventDefault();
			const data = new FormData(form);
			const q = String(data.get("q") ?? "").trim();
			if (!q) return;
			const href = wordsPageHref(q, import.meta.env.BASE_URL);
			window.location.href = href;
		});
	}
</script>

<style>
	.hero {
		min-height: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 2rem 1.25rem 4rem;
		box-sizing: border-box;
		max-width: 36rem;
		margin: 0 auto;
		gap: 0.75rem;
	}

	.eyebrow {
		margin: 0;
		font-size: 0.75rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--muted, #5c6670);
	}

	h1 {
		margin: 0;
		font-size: clamp(1.75rem, 4vw, 2.25rem);
		font-weight: 700;
		letter-spacing: -0.02em;
	}

	.lede {
		margin: 0;
		text-align: center;
		line-height: 1.55;
		color: var(--muted, #3d4650);
	}

	.search {
		display: flex;
		width: 100%;
		gap: 0.5rem;
		margin-top: 0.5rem;
	}

	.search input {
		flex: 1;
		min-width: 0;
		padding: 0.65rem 0.75rem;
		font-size: 1rem;
		border: 1px solid #c9d1d9;
		border-radius: 8px;
	}

	.search button {
		padding: 0.65rem 1rem;
		font-size: 1rem;
		font-weight: 600;
		color: #fff;
		background: #0d47a1;
		border: none;
		border-radius: 8px;
		cursor: pointer;
	}

	.search button:hover {
		background: #0a3d88;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		border: 0;
	}
</style>
